---
const title = Astro.props.title || "Pendaftaran Santri Online";
const description = Astro.props.description || "Pendaftaran Santri Online";
---

<!doctype html>
<html lang="en" data-theme="cupcake">
  <head>
    <script is:inline>
      (function () {
        var theme = localStorage.getItem("theme") || "cupcake";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/src/assets/global.css" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
