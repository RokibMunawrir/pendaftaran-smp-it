---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/ui/navbar-page.tsx";
import Hero from "../components/page/hero.tsx";
import About from "../components/page/about.tsx";
import Superior from "../components/page/superior.tsx";
import Agenda from "../components/page/agenda.tsx";
import Cost from "../components/page/cost.tsx";
import Info from "../components/page/info.tsx";
import FAQ from "../components/page/faq.tsx";
import Contact from "../components/page/contact.tsx";
import Footer from "../components/page/footer.tsx";
import db from "../db";
import { settings } from "../db/schema/settings";
import { announcements as announcementsTable } from "../db/schema/announcement";
import { eq, desc } from "drizzle-orm";

let webData: any = null;
try {
  const setting = await db.select().from(settings).limit(1);
  if (setting && setting.length > 0) {
    const s = setting[0];
    const parseJson = (val: any) => {
      if (typeof val === "string") {
        try {
          return JSON.parse(val);
        } catch (e) {
          return null;
        }
      }
      return val;
    };

    webData = {
      siteName: s.siteName || "",
      logo: s.logo || "",
      announcementBanner: s.announcementBanner || "",
      hero: {
        title: s.heroTitle || "",
        subtitle: s.heroSubtitle || "",
        ctaText: s.heroCtaText || "",
        ctaLink: s.heroCtaLink || "",
        backgroundImage: s.heroImage || "",
      },
      about: {
        title: s.aboutTitle || "",
        description: s.aboutDescription || "",
        image: s.aboutImage || "",
      },
      features: parseJson(s.features) || [],
      agenda: parseJson(s.agenda) || [],
      biaya: parseJson(s.biaya) || [],
      faq: parseJson(s.faq) || [],
      contact: {
        address: s.contactAddress || "",
        phone: s.contactPhone || "",
        email: s.contactEmail || "",
        mapEmbed: s.contactMapEmbed || "",
      },
      social: {
        facebook: s.socialFacebook || "",
        instagram: s.socialInstagram || "",
        youtube: s.socialYoutube || "",
        whatsapp: s.socialWhatsapp || "",
      },
      footer: s.footer || "",
      announcements: [],
    };

    const news = await db
      .select()
      .from(announcementsTable)
      .where(eq(announcementsTable.isPublished, true))
      .orderBy(desc(announcementsTable.createdAt));

    webData.announcements = news.map((a) => ({
      id: a.id,
      title: a.title,
      content: a.content,
      date: new Date(a.createdAt).toLocaleDateString("id-ID", {
        day: "2-digit",
        month: "short",
        year: "numeric",
      }),
      isImportant: a.isImportant,
    }));
  }
} catch (error) {
  console.error("Error fetching web setting:", error);
}
---

<Layout
  title="SMP IT Darussalam Luwuk Banggai"
  description="SMP IT Darussalam Luwuk Banggai - Pendaftaran Santri Online"
  ogTitle={webData?.siteName}
  ogDescription={webData?.hero?.subtitle}
  ogImage={webData?.hero?.backgroundImage}
  ogType="website"
>
  <Navbar
    client:only="react"
    siteName={webData?.siteName}
    logo={webData?.logo}
    announcementBanner={webData?.announcementBanner}
  />
  <Hero
    client:only="react"
    title={webData?.hero?.title}
    subtitle={webData?.hero?.subtitle}
    ctaText={webData?.hero?.ctaText}
    ctaLink={webData?.hero?.ctaLink}
    backgroundImage={webData?.hero?.backgroundImage}
  />
  <About
    client:only="react"
    title={webData?.about?.title}
    description={webData?.about?.description}
    image={webData?.about?.image}
  />
  <Superior client:only="react" features={webData?.features} />
  <Agenda client:only="react" agenda={webData?.agenda} />
  <Cost client:only="react" biaya={webData?.biaya} />
  <Info client:only="react" announcements={webData?.announcements} />
  <FAQ client:only="react" faq={webData?.faq} />
  <Contact
    client:only="react"
    contact={webData?.contact}
    social={webData?.social}
  />
  <Footer
    client:only="react"
    siteName={webData?.siteName}
    logo={webData?.logo}
    footerText={webData?.footer}
    contact={webData?.contact}
    social={webData?.social}
  />
</Layout>
