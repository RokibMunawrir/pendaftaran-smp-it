---
import Layout from "../../../../layouts/Layout.astro";
import DetailPendaftar from "../../../../components/ui/admin/bio-data";
import { getRegistrationByUserId } from "../../../../db/queries/registrations";
import { getDocumentsByRegistrationId } from "../../../../db/queries/documents";
import { getPaymentByRegistrationId } from "../../../../db/queries/payment";
import { auth } from "../../../../lib/auth";

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

if (!session || session.user.role !== "admin") {
  return Astro.redirect("/login");
}

const { userId } = Astro.params;
const registration = userId ? await getRegistrationByUserId(userId) : null;
const documents = registration ? await getDocumentsByRegistrationId(registration.id) : [];
const payment = registration ? await getPaymentByRegistrationId(registration.id) : null;
---

<Layout title="Detail Pendaftar" description="Detail Pendaftar">
  <DetailPendaftar client:load data={registration} documents={documents} payment={payment} />
</Layout>