---
import Layout from "../../../layouts/Layout.astro";
import DashboardContent from "../../../components/ui/admin/dashboard";
import { getDashboardStats, getMonthlyStats, getRecentRegistrants } from "../../../db/queries/dashboard";
import { auth } from "../../../lib/auth";

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

if (!session) {
  return Astro.redirect("/login");
}

const stats = await getDashboardStats();
const monthly = await getMonthlyStats();
const recent = await getRecentRegistrants();
---

<Layout title="Dashboard" description="Dashboard">
  <DashboardContent client:only="react" stats={stats} monthly={monthly} recent={recent} />
</Layout>
