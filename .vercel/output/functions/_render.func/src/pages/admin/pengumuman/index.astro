---
import Layout from "../../../layouts/Layout.astro";
import Announcement from "../../../components/ui/admin/announcement";
import { getAnnouncements } from "../../../db/queries/announcement";
import { auth } from "../../../lib/auth";

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

if (!session) {
  return Astro.redirect("/login");
}

const announcements = await getAnnouncements()

---

<Layout title="Pengumuman" description="Pengumuman">
  <Announcement client:only="react" announcements={announcements}/>
</Layout>